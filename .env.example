# Copy to .env and fill in. Do not commit .env (see .gitignore).

# HTTP port (default 3000)
# PORT=3000

# MongoDB connection string (required for workspaces, brands in Mongo, client dashboards)
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority

# Database name on the cluster (default: gads_report)
# MONGODB_DB=gads_report

# Secret for signing internal session cookies (use a long random string in production)
# SESSION_SECRET=

# Legacy file-based login fallback (disabled by default for security).
# Set to true only for local/dev emergency fallback with credentials.json.
# ALLOW_LEGACY_FILE_AUTH=false

# Optional: create first admin user when internal_users collection is empty (first deploy only)
# INITIAL_ADMIN_USERNAME=
# INITIAL_ADMIN_PASSWORD=

# Optional: set to production so session cookies use the Secure flag behind HTTPS
# NODE_ENV=production
